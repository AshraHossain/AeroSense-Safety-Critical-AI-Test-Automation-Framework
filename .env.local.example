# Local Development Environment Configuration
# Copy to .env.local and customize for your machine
# .env.local is git-ignored (secrets are safe)

# PostgreSQL connection (local docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aerosense

# Claude AI model (pinned to specific version)
CLAUDE_MODEL=claude-sonnet-4-6

# API server port
PORT=8000

# Logging level: debug, info, warning, error
LOG_LEVEL=debug

# Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: Override defaults for development
# PYTEST_TIMEOUT=10
# REDIS_URL=redis://localhost:6379/0
