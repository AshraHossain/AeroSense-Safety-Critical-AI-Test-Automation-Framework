# AeroSense-TestForge Environment Configuration
# Copy to .env and fill in actual values before running

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aerosense

# Claude AI model, explicitly pinned to version (required)
CLAUDE_MODEL=claude-sonnet-4-6

# Server port (optional, default: 8000)
PORT=8000

# Logging level: debug, info, warning, error (optional, default: info)
LOG_LEVEL=info

# Anthropic API key (optional if using ANTHROPIC_API_KEY env var)
ANTHROPIC_API_KEY=sk-ant-...
